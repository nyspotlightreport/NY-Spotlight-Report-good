# NY Spotlight Report — Environment Variables
# Copy this to .env and fill in values, or set in Netlify dashboard

# Authentication
JWT_SECRET=                    # Random 32+ character string for signing JWTs
ADMIN_EMAIL=                   # Admin login email address
ADMIN_PASSWORD_HASH=           # bcrypt hash of admin password (generate with: npx bcryptjs hash "yourpassword")

# Content APIs
ANTHROPIC_API_KEY=             # Claude API key for editorial enhancement
GUARDIAN_API_KEY=              # The Guardian API key
NEWSAPI_KEY=                   # NewsAPI.org key
ALPHA_VANTAGE_API_KEY=         # Alpha Vantage stock data key

# CRM & Newsletter
HUBSPOT_API_KEY=               # HubSpot CRM API key
BEEHIIV_API_KEY=               # Beehiiv newsletter API key
BEEHIIV_PUB_ID=                # Beehiiv publication ID

# Social Media
FACEBOOK_APP_ID=               # Facebook App ID
FACEBOOK_APP_SECRET=           # Facebook App Secret

# Twilio (Voice AI Receptionist)
TWILIO_ACCOUNT_SID=            # Twilio Account SID
TWILIO_AUTH_TOKEN=             # Twilio Auth Token (for webhook signature validation)
TWILIO_PHONE_NUMBER=           # Twilio phone number (e.g., +16318929817)

# Webhooks
GUMROAD_WEBHOOK_SECRET=        # Gumroad webhook HMAC secret

# Infrastructure
GH_PAT=                        # GitHub Personal Access Token (for saving secrets)
BUTLER_API_KEY=                # Butler API key for automated secret management

# Optional
ALLOWED_ORIGIN=https://nyspotlightreport.com   # CORS allowed origin
